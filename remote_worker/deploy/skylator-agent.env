# Environment for the Skylator agent systemd / launchd service.
# Point this at your master host. Optionally pre-load a model so the agent can resume
# autonomously after a reboot without waiting for the host to push a load_model chunk.

SKYLATOR_HOST_URL=http://192.168.1.100:5000

# Optional extra args, e.g. preload a model for autonomous restart:
#   --model-path models_cache/Qwen3.5-27B-GGUF/qwen3.5-27b-q4_k_m.gguf
SKYLATOR_EXTRA_ARGS=
